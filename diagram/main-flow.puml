@startuml
skinparam backgroundColor #FAFAFA
skinparam activityBorderColor #888888
skinparam activityBackgroundColor #FFFFFF
skinparam arrowColor #444444
skinparam roundcorner 10

skinparam partition {
    BackgroundColor #EEF4FF
    BorderColor #4A90D9
    FontColor #2C5F9E
    FontStyle bold
}

skinparam diamond {
    BackgroundColor #FFF9E6
    BorderColor #E6A817
}

skinparam note {
    BackgroundColor #FFF3CD
    BorderColor #E6A817
}

start

:주문 요청; <<#D4EDDA>>

partition "TX1" {
    :재고 차감, 주문/결제, Outbox 저장; <<#D4EDDA>>
}

:CDC → Kafka 발행; <<#D0E8FF>>

if (결제 선점 성공?\n(Redisson 분산락 획득)) then (yes)
    :PG 호출\n(트랜잭션 없음); <<#D4EDDA>>
    if (PG결과) then (성공)
        partition "TX2" {
            :결제 확정\nOutbox 적재; <<#D4EDDA>>
        }
    else (실패)
        :재시도 / 실패 확정; <<#FFE8CC>>
        note right: 실패 시 DLQ 처리\n별도 다이어그램 참고
        stop
    endif
else (no)
    :중복 skip; <<#E8E8E8>>
    stop
endif

:CDC → Kafka 발행; <<#D0E8FF>>

partition "TX3" {
    :완료된 이벤트 멱등성 체크; <<#D4EDDA>>
    if (결제 성공?) then (yes)
        :주문 완료\n장바구니 삭제; <<#D4EDDA>>
    else (no)
        :주문 실패\n재고 롤백; <<#FFD6D6>>
    endif
    :완료된 이벤트 저장; <<#D4EDDA>>
}

if (후처리 실패?) then (yes)
    : 실패 시 DLQ 처리\n별도 다이어그램 참고;
    stop
endif

stop

note right
  **장기 미처리 결제 복구 스케줄러**
  2분 이상 진행중인 결제 건 감지
  → 실패 확정 + 재고 롤백
end note

@enduml