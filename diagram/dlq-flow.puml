@startuml
skinparam activityBorderColor #888888
skinparam activityBackgroundColor #FFFFFF
skinparam arrowColor #444444
skinparam roundcorner 10

skinparam partition {
    BackgroundColor #FFF0F0
    BorderColor #D9534F
    FontColor #A02020
    FontStyle bold
}

skinparam note {
    BackgroundColor #FFF3CD
    BorderColor #E6A817
}

start
:PG 호출;
if (결제 성공?) then (no)
    if (실패 유형?) then (비즈니스\n잔액부족/카드거절)
        :즉시 실패; <<#FFD6D6>>
        stop
    else (Transient\n네트워크/타임아웃)
        :재시도; <<#FFE8CC>>
        if (재시도 5회 소진?) then (yes)
        else (no)
            stop
        endif
    endif
else (yes)
    if (결제 후처리 실패?) then (no)
        stop
    endif
    note left: 주문상태 업데이트\n장바구니 삭제/재고 롤백
endif

partition "DLQ 수신" {
    :PaymentDlqLog 저장; <<#FFD6D6>>
    :Slack 알람 발송; <<#FFD6D6>>
}
stop

@enduml